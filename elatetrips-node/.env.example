# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins (frontend dev server)
CORS_ORIGINS=http://localhost:3000

# MongoDB — copy this file to `.env` and fill in real values there (.env is
# git-ignored; NEVER put real credentials in this committed example).
#
# Local default:
MONGODB_URI=mongodb://127.0.0.1:27017/elatetrips
#
# MongoDB Atlas (SRV form — preferred when your runtime can resolve SRV DNS):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/elatetrips?retryWrites=true&w=majority
#
# Atlas standard form — use this if Node's DNS can't resolve SRV records
# (querySrv ECONNREFUSED); paste the three shard hosts + replicaSet from Atlas:
# MONGODB_URI=mongodb://<user>:<password>@<host1>:27017,<host2>:27017,<host3>:27017/elatetrips?ssl=true&replicaSet=<replicaSet>&authSource=admin&retryWrites=true&w=majority

# Auth (OTP -> JWT)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# OTP delivery providers — ALL OPTIONAL. Any channel without a provider falls
# back to printing the OTP in the server console, and in non-production the
# API response also includes `devOtp`, so the flow is fully testable with no
# third-party account at all.
# ---------------------------------------------------------------------------

# EMAIL OTP — Brevo (https://www.brevo.com), free tier: 300 emails/day, no
# credit card. Setup: sign up -> Settings -> SMTP & API -> Generate API key
# (starts with "xkeysib-"). BREVO_FROM_EMAIL must be the email you signed up
# with (or a verified sender from Settings -> Senders).
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=ElateTrips

# SMS OTP option A — Twilio (https://www.twilio.com/try-twilio), free trial
# credit, no card. Limitation: trial accounts can only text numbers you verify
# in the Twilio console (fine for testing). Get a trial number, then copy the
# Account SID + Auth Token from the console dashboard.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMS OTP option B — Fast2SMS (https://www.fast2sms.com), India-only, ₹50 free
# signup credit. The OTP route used here works without DLT registration.
# Setup: sign up -> Dev API section -> copy the API key.
# If both Twilio and Fast2SMS are configured, Twilio wins.
FAST2SMS_API_KEY=
